# ─────────────────────────────────────────────────────────────────────────
# BYO-KEY MODEL: these env vars are OPTIONAL.
# In production, each agency enters THEIR OWN keys in the tool's settings and
# those are sent per-request as headers. The backend uses them transiently and
# never stores them. Set the vars below only if you want a personal/default
# fallback (e.g. your own testing) when a request arrives with no key headers.
# ─────────────────────────────────────────────────────────────────────────

# Optional fallback keys (leave blank for a pure BYO-key deployment):
GOOGLE_PLACES_API_KEY=
SERPAPI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
LEAD_WEBHOOK_URL=

# Geo-grid defaults (used when a request doesn't override via header):
GEO_GRID_SIZE=5
GEO_GRID_RADIUS_MI=3

# Caching (this is YOUR infra, shared across agencies to cut everyone's API calls):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_TTL_SECONDS=86400

# CORS — comma-separated origins allowed to call the API, or * for dev.
ALLOWED_ORIGINS=*
